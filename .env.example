# GHCR image to run. Pin to a digest in production:
#   IMAGE_TAG=ghcr.io/mmrmagno/marc-os-blog@sha256:...
IMAGE_TAG=ghcr.io/mmrmagno/marc-os-blog:latest

# Name of the existing docker network that Nginx Proxy Manager lives on.
# Find it with: `docker network ls`  (often something like `npm_default`
# or `proxy`). The blog container joins this network so NPM can reach it
# by container name (`marc-os-app`).
PROXY_NETWORK=npm_default
