---
import BaseLayout from '@layouts/BaseLayout.astro';

import Terminal from '@components/Terminal.astro';

const notFoundTerminal = ` _  _    ___   _  _
| || |  / _ \\ | || |
| || |_| | | || || |_
|__   _|| |_| ||__   _|
   |_|  \\___/    |_|`;
---

<BaseLayout title="404 — not found" description="Page not found" noIndex>
  <section class="container notfound">
    <Terminal title="─[ 404 ]" body={notFoundTerminal} tone="danger" compact />
    <h1>signal lost</h1>
    <p>the path <code>{Astro.url.pathname}</code> doesn't resolve.</p>
    <p><a href="/" class="btn">→ Return home</a></p>
  </section>
</BaseLayout>

<style>
  .notfound {
    padding: 3rem 1.25rem;
    text-align: center;
  }

  h1 {
    color: var(--ctp-red);
    margin: 0 0 0.6rem;
  }

  .btn {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.55em 1.1em;
    background: color-mix(in srgb, var(--ctp-red) 14%, transparent);
    color: var(--ctp-red);
    border: 1px solid color-mix(in srgb, var(--ctp-red) 50%, transparent);
    border-radius: var(--radius);
    transition: all 150ms ease;
  }
  .btn:hover {
    background: color-mix(in srgb, var(--ctp-red) 25%, transparent);
    border-color: var(--ctp-red);
    transform: translateY(-1px);
  }
</style>
