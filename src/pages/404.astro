---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="404 — not found" description="Page not found" noIndex>
  <section class="container notfound">
    <div class="terminal">
      <pre class="ascii" aria-hidden="true"> _  _    ___   _  _
| || |  / _ \ | || |
| || |_| | | || || |_
|__   _|| |_| ||__   _|
   |_|  \___/    |_|</pre>
    </div>
    <h1>signal lost</h1>
    <p>the path <code>{Astro.url.pathname}</code> doesn't resolve.</p>
    <p><a href="/" class="btn">→ return home</a></p>
  </section>
</BaseLayout>

<style>
  .notfound {
    padding: 3rem 1.25rem;
    text-align: center;
  }

  .terminal {
    margin: 0 auto 1.5rem;
    display: inline-block;
    text-align: left;
    border: 1px solid var(--ctp-red);
    border-radius: var(--radius);
    background: var(--bg-deep);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    filter: drop-shadow(0 0 8px color-mix(in srgb, var(--ctp-red) 40%, transparent));
  }

  .ascii {
    display: block;
    margin: 0;
    padding: 0.8rem 1.2rem !important;
    background: transparent !important;
    border: 0 !important;
    color: var(--ctp-red);
    font-size: inherit;
    line-height: 1.4;
    text-shadow: 0 0 10px color-mix(in srgb, var(--ctp-red) 30%, transparent);
  }

  h1 {
    color: var(--ctp-red);
    margin: 0 0 0.6rem;
  }

  .btn {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.55em 1.1em;
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    transition: all 150ms ease;
  }
  .btn:hover {
    background: color-mix(in srgb, var(--accent) 25%, transparent);
    transform: translateY(-1px);
  }
</style>
