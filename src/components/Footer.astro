---
import { SITE } from '@lib/config';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-wide footer-inner">
    <div class="footer-left">
      <span class="dim">// {year} · {SITE.author}</span>
    </div>
    <div class="footer-right">
      <a href={SITE.social.github} rel="me noopener" class="footer-link">github</a>
      <span class="dim">·</span>
      <a href={SITE.social.linkedin} rel="me noopener" class="footer-link">linkedin</a>
      <span class="dim">·</span>
      <a href={SITE.social.email} class="footer-link">email</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding: 1.4rem 0 2rem;
    background: color-mix(in srgb, var(--bg-elevated) 70%, transparent);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.6rem 1rem;
    font-size: 0.82rem;
    color: var(--text-dim);
  }

  .footer-left, .footer-right {
    display: flex;
    gap: 0.55rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .dim { color: var(--text-dim); }

  .footer-link {
    color: var(--text-muted);
    border: 0;
  }
  .footer-link:hover {
    color: var(--accent);
  }
</style>
