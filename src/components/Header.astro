---
import { SITE } from '@lib/config';

const path = Astro.url.pathname;
---

<header class="site-header">
  <div class="container-wide header-inner">
    <a href="/" class="brand" aria-label="Home">
      <span class="prompt">marc@os</span>
      <span class="sep">:</span>
      <span class="cwd">~{path === '/' ? '' : path.replace(/\/$/, '')}</span>
      <span class="cursor" aria-hidden="true">▊</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {SITE.nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[{ active: path === item.href || (item.href !== '/' && path.startsWith(item.href)) }]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-elevated) 80%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .brand {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text-muted);
    border: 0;
    white-space: nowrap;
  }

  .brand:hover { color: var(--text-muted); }

  .brand .prompt { color: var(--ctp-green); }
  .brand .sep { color: var(--ctp-overlay1); }
  .brand .cwd { color: var(--ctp-blue); }
  .brand .cursor {
    color: var(--ctp-green);
    animation: blink 1.1s steps(2) infinite;
    margin-left: 2px;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 1.1rem;
    margin: 0;
    padding: 0;
    font-size: 0.9rem;
  }

  nav a {
    color: var(--text-muted);
    border: 0;
    padding: 0.3em 0;
    position: relative;
  }

  nav a:hover { color: var(--accent); }

  nav a.active {
    color: var(--accent);
  }

  nav a.active::before {
    content: '> ';
    color: var(--accent);
  }
</style>
